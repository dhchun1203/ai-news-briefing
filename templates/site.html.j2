<!DOCTYPE html>
{% set default_lang = default_lang|default('ko') %}
{% set title_ko = "AI 뉴스 브리핑 — " + date + (" (지난 기록)" if is_archive else "") %}
{% set title_en = "AI News Briefing — " + date + (" (Archive)" if is_archive else "") %}
{% set desc_ko = date + "자 AI 뉴스 요약과 시사점" %}
{% set desc_en = "Daily AI news summaries and takeaways — " + date %}
{% set title_default = title_en if default_lang == 'en' else title_ko %}
{% set desc_default = desc_en if default_lang == 'en' else desc_ko %}
<html lang="{{ default_lang }}" data-lang="{{ default_lang }}" data-title-ko="{{ title_ko }}" data-title-en="{{ title_en }}">
<head>
<meta charset="UTF-8">
<title>{{ title_default }}</title>
<meta name="description" content="{{ desc_default }}">
<meta property="og:type" content="website">
<meta property="og:title" content="{{ title_default }}">
<meta property="og:description" content="{{ desc_default }}">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ title_default }}">
<meta name="twitter:description" content="{{ desc_default }}">
<link rel="canonical" href="{{ canonical_url }}">
<meta name="robots" content="index, follow">
<meta property="og:url" content="{{ canonical_url }}">
<meta property="og:image" content="{{ og_image_url }}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content="AI 뉴스 브리핑 · Daily AI Thread">
<meta name="twitter:image" content="{{ og_image_url }}">
<link rel="icon" type="image/svg+xml" href="{{ css_prefix }}favicon.svg">
{% if hreflang_ko_url and hreflang_en_url %}
<link rel="alternate" hreflang="ko" href="{{ hreflang_ko_url }}">
<link rel="alternate" hreflang="en" href="{{ hreflang_en_url }}">
<link rel="alternate" hreflang="x-default" href="{{ hreflang_ko_url }}">
{% endif %}
{% if google_site_verification %}<meta name="google-site-verification" content="{{ google_site_verification }}">{% endif %}
{% if naver_site_verification %}<meta name="naver-site-verification" content="{{ naver_site_verification }}">{% endif %}
<script type="application/ld+json">{{ jsonld|tojson }}</script>
<script>
(function () {
  function getCookie(name) {
    var match = document.cookie.match(new RegExp("(?:^|; )" + name + "=([^;]*)"));
    return match ? decodeURIComponent(match[1]) : null;
  }
  try {
    // 처음 방문(쿠키 없음)이면 시스템 설정과 무관하게 항상 라이트 모드로 뜬다.
    var t = getCookie("theme");
    if (t === "dark" || t === "light") document.documentElement.setAttribute("data-theme", t);
    {% if default_lang == 'en' %}
    // 영어권 착지 페이지(/en/) — 과거에 저장된 언어 선호와 무관하게 항상 영어로
    // 보여주고, 이후 다른 페이지로 이동해도 영어가 유지되도록 저장해둔다.
    localStorage.setItem("lang", "en");
    {% else %}
    var l = localStorage.getItem("lang");
    if (l === "ko" || l === "en") {
      document.documentElement.setAttribute("data-lang", l);
      document.documentElement.setAttribute("lang", l);
      var titleAttr = l === "en" ? "data-title-en" : "data-title-ko";
      var storedTitle = document.documentElement.getAttribute(titleAttr);
      if (storedTitle) document.title = storedTitle;
    }
    {% endif %}
  } catch (e) {}
})();
</script>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@400;600;700&display=swap">
<link rel="stylesheet" href="{{ css_prefix }}site-base.css">
<link rel="stylesheet" href="{{ css_prefix }}site-mobile.css" media="(max-width: 767px)">
<link rel="stylesheet" href="{{ css_prefix }}site-desktop.css" media="(min-width: 768px)">
<script defer src="/_vercel/insights/script.js"></script>
</head>
<body>
<header class="site-header">
  <div class="utility-bar">
    <a class="glossary-nav-link" href="{{ css_prefix }}glossary.html">
      <span class="lang-ko">용어사전</span>
      <span class="lang-en">Glossary</span>
    </a>
    <div class="share-wrap" id="share-wrap">
      <button id="share-button" class="share-button" type="button" aria-label="링크 복사 / Copy link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
      </button>
      <span class="share-tooltip" id="share-tooltip" role="status" aria-live="polite">
        <span class="lang-ko">복사되었습니다</span>
        <span class="lang-en">Copied!</span>
      </span>
    </div>
    <div class="lang-select" id="lang-select">
      <button type="button" class="lang-select-trigger" id="lang-select-trigger" aria-haspopup="listbox" aria-expanded="false">
        <span class="lang-select-current lang-ko">한국어</span>
        <span class="lang-select-current lang-en">English</span>
        <span class="lang-select-caret" aria-hidden="true">▾</span>
      </button>
      <ul class="lang-select-list" id="lang-select-list" role="listbox" hidden>
        <li role="option" data-lang-value="ko">한국어</li>
        <li role="option" data-lang-value="en">English</li>
      </ul>
    </div>
    <button id="theme-toggle" class="theme-toggle" type="button" role="switch" aria-checked="false" aria-label="다크모드 전환">
      <span class="theme-toggle-thumb">
        <span class="icon-moon" aria-hidden="true">&#9789;</span>
        <span class="icon-sun" aria-hidden="true">&#9728;</span>
      </span>
    </button>
  </div>
  <div class="header-inner">
    <h1>
      <a href="{{ css_prefix }}index.html">
        <span class="lang-ko">AI 뉴스 브리핑</span>
        <span class="lang-en">AI News Briefing</span>
      </a>
    </h1>
    <p class="tagline">
      <span class="lang-ko">매일 아침 8시 · AI 기사 {{ articles|length }}건의 요약과 시사점</span>
      <span class="lang-en">Daily at 8AM KST · Summaries and takeaways from {{ articles|length }} AI articles</span>
    </p>
    <p class="mission">
      <span class="lang-ko">
        <span class="mission-para">TechCrunch·VentureBeat 같은 업계 매체, OpenAI·Google DeepMind의 공식 발표, MarkTechPost·MIT Technology Review 같은 기술 전문 매체, Hacker News의 커뮤니티 신호까지 — 서로 다른 관점을 매일 교차 확인합니다.</span>
        <span class="mission-para mission-emphasis">"무슨 일이 있었는지"보다 "왜 중요한지"를 짚어, 흩어진 뉴스를 하루 단위로 이어지는 흐름으로 읽을 수 있게 하는 것이 이 브리핑의 목표입니다.</span>
      </span>
      <span class="lang-en">
        <span class="mission-para">We cross-check industry press (TechCrunch, VentureBeat), official lab announcements (OpenAI, Google DeepMind), technical outlets (MarkTechPost, MIT Technology Review), and community signal from Hacker News — deliberately mixing perspectives instead of trusting a single narrative.</span>
        <span class="mission-para mission-emphasis">The goal isn't just what happened, but why it matters, so scattered daily headlines add up to a coherent read on where AI is heading.</span>
      </span>
    </p>
  </div>
</header>

<main class="content">
  <section class="subscribe-box" aria-label="이메일 구독">
    <p class="subscribe-title">
      <span class="lang-ko">매일 아침 이메일로 받아보기</span>
      <span class="lang-en">Get it in your inbox every morning</span>
    </p>
    <p class="subscribe-desc">
      <span class="lang-ko">헤드라인과 한 줄 요약을 매일, 한 주를 정리하는 종합 회고를 매주 일요일에 보내드려요.</span>
      <span class="lang-en">Daily headlines and summaries, plus a synthesis of the week every Sunday.</span>
    </p>
    <form class="subscribe-form" id="subscribe-form">
      <input type="email" name="email" required class="subscribe-input" placeholder="you@example.com" aria-label="이메일 주소">
      <button type="submit" class="subscribe-submit">
        <span class="lang-ko">구독하기</span>
        <span class="lang-en">Subscribe</span>
      </button>
    </form>
    <p class="subscribe-status" id="subscribe-status" role="status" aria-live="polite"></p>
  </section>

  <div class="date-bar">
    <span class="date-label">{{ date }}</span>
    {% if is_archive %}
      <span class="archive-badge">
        <span class="lang-ko">지난 기록</span>
        <span class="lang-en">Past Edition</span>
      </span>
      <a class="back-link" href="{{ home_link }}">
        <span class="lang-ko">오늘자 브리핑 보기 →</span>
        <span class="lang-en">View today's briefing →</span>
      </a>
    {% endif %}
  </div>

  {% if show_weekly_banner and weekly_labels %}
  <a class="weekly-banner" href="{{ weekly_link_prefix }}{{ weekly_labels[0] }}.html">
    <span class="lang-ko">이번 주 AI 흐름 정리 보기 → {{ weekly_labels[0] }} 주간 회고</span>
    <span class="lang-en">This week's AI trends, summarized → {{ weekly_labels[0] }} Weekly Recap</span>
  </a>
  {% endif %}

  {% if not articles %}
  <p class="empty-state">
    <span class="lang-ko">오늘은 조건에 맞는 기사를 찾지 못했습니다.</span>
    <span class="lang-en">No qualifying articles were found today.</span>
  </p>
  {% endif %}

  {% if daily_insight %}
  <section class="insight" aria-label="오늘의 인사이트">
    <p class="insight-label">
      <span class="lang-ko">오늘의 인사이트</span>
      <span class="lang-en">Today's Insight</span>
    </p>
    <h2 class="insight-headline">
      <span class="lang-ko">{{ daily_insight.headline_ko|safe }}</span>
      <span class="lang-en">{{ daily_insight.headline_en|safe }}</span>
    </h2>
    <div class="insight-body">
      <div class="lang-ko">
        {% for para in daily_insight.paragraphs_ko %}<p>{{ para|safe }}</p>{% endfor %}
      </div>
      <div class="lang-en">
        {% for para in daily_insight.paragraphs_en %}<p>{{ para|safe }}</p>{% endfor %}
      </div>
    </div>
    {% if daily_insight.watch_ko %}
    <p class="insight-watch">
      <span class="insight-watch-label">
        <span class="lang-ko">지켜볼 신호</span>
        <span class="lang-en">Signal to watch</span>
      </span>
      <span class="lang-ko">{{ daily_insight.watch_ko|safe }}</span>
      <span class="lang-en">{{ daily_insight.watch_en|safe }}</span>
    </p>
    {% endif %}
  </section>
  {% endif %}

  {% if articles %}
  <nav class="toc" aria-label="목차">
    <h2 class="toc-title">
      <span class="lang-ko">목차</span>
      <span class="lang-en">Contents</span>
    </h2>
    <ol class="toc-list">
      {% for article in articles %}
      <li><a href="#article-{{ loop.index }}"><span class="toc-num">{{ "%02d"|format(loop.index) }}</span><span class="toc-text">{{ article.title }}</span></a></li>
      {% endfor %}
    </ol>
  </nav>
  {% endif %}

  <div class="article-list">
    {% for article in articles %}
    <article class="article-card" id="article-{{ loop.index }}">
      <div class="article-meta">
        <span class="source">{{ article.source }}</span>
        {% if article.source_type == "primary" %}
        <span class="source-badge source-badge-primary">
          <span class="lang-ko">공식 발표</span>
          <span class="lang-en">Official</span>
        </span>
        {% elif article.source_type == "community" %}
        <span class="source-badge source-badge-community">
          <span class="lang-ko">커뮤니티</span>
          <span class="lang-en">Community</span>
        </span>
        {% else %}
        <span class="source-badge source-badge-press">
          <span class="lang-ko">보도</span>
          <span class="lang-en">Press</span>
        </span>
        {% endif %}
        <span class="dot">·</span>
        <span class="published">{{ article.published_at[:10] }}</span>
      </div>
      <h2 class="article-title">
        <a href="{{ article.link }}" target="_blank" rel="noopener noreferrer">{{ article.title }}</a>
      </h2>
      <div class="article-summary">
        <h3 class="block-label">
          <span class="lang-ko">요약</span>
          <span class="lang-en">Summary</span>
        </h3>
        <p class="lang-ko">{{ article.summary_ko|safe }}</p>
        <p class="lang-en">{{ article.summary_en|safe }}</p>
      </div>
      <div class="article-implication">
        <h3 class="block-label">
          <span class="lang-ko">이 기사가 시사하는 점</span>
          <span class="lang-en">Why It Matters</span>
        </h3>
        <p class="lang-ko">{{ article.implication_ko|safe }}</p>
        <p class="lang-en">{{ article.implication_en|safe }}</p>
      </div>
    </article>
    {% endfor %}
  </div>

  {% if archives %}
  <section class="archive-section">
    <h2 class="archive-title">
      <span class="lang-ko">지난 브리핑</span>
      <span class="lang-en">Past Briefings</span>
    </h2>
    <div class="archive-search">
      <input type="search" id="archive-search-input" class="archive-search-input"
             data-placeholder-ko="지난 기사 검색..." data-placeholder-en="Search past articles..."
             aria-label="지난 기사 검색 / Search past articles">
      <ul class="archive-search-results" id="archive-search-results" hidden></ul>
    </div>
    <ul class="archive-list">
      {% for a in archives %}
      <li><a href="{{ archive_link_prefix }}{{ a }}.html">{{ a }}</a></li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  {% if weekly_labels %}
  <section class="archive-section">
    <h2 class="archive-title">
      <span class="lang-ko">주간 회고</span>
      <span class="lang-en">Weekly Recaps</span>
    </h2>
    <ul class="archive-list">
      {% for w in weekly_labels %}
      <li><a href="{{ weekly_link_prefix }}{{ w }}.html">{{ w }}</a></li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}
</main>

<footer class="site-footer">
  <p>
    <span class="lang-ko">매일 08:00 KST 자동 생성 · 마지막 생성: {{ generated_at }}</span>
    <span class="lang-en">Auto-generated daily at 08:00 KST · Last updated: {{ generated_at }}</span>
  </p>
</footer>

<div class="term-panel-backdrop" id="term-panel-backdrop" hidden></div>
<aside class="term-panel" id="term-panel" aria-hidden="true">
  <button type="button" class="term-panel-close" id="term-panel-close" aria-label="닫기 / Close">&times;</button>
  <p class="term-panel-label">
    <span class="lang-ko">용어 설명</span>
    <span class="lang-en">Glossary</span>
  </p>
  <h3 class="term-panel-title" id="term-panel-title"></h3>
  <p class="term-panel-body" id="term-panel-body"></p>
</aside>
<script type="application/json" id="glossary-data">{{ glossary|tojson }}</script>

<script>
(function () {
  var updatePlaceholders = function () {
    var lang = document.documentElement.getAttribute("data-lang") || "ko";
    Array.prototype.forEach.call(document.querySelectorAll("[data-placeholder-ko]"), function (el) {
      var attr = lang === "en" ? "data-placeholder-en" : "data-placeholder-ko";
      el.setAttribute("placeholder", el.getAttribute(attr) || "");
    });
  };
  updatePlaceholders();

  var themeBtn = document.getElementById("theme-toggle");
  if (themeBtn) {
    // 시스템 다크모드 설정과 무관하게, 쿠키에 저장된 명시적 선택이 없으면 항상 라이트가 기본값.
    var isDarkActive = function () {
      return document.documentElement.getAttribute("data-theme") === "dark";
    };
    var setThemeCookie = function (value) {
      var expires = new Date();
      expires.setTime(expires.getTime() + 365 * 24 * 60 * 60 * 1000);
      document.cookie = "theme=" + encodeURIComponent(value) + "; expires=" + expires.toUTCString() + "; path=/; SameSite=Lax";
    };
    themeBtn.setAttribute("aria-checked", String(isDarkActive()));
    themeBtn.addEventListener("click", function () {
      var next = isDarkActive() ? "light" : "dark";
      document.documentElement.setAttribute("data-theme", next);
      setThemeCookie(next);
      themeBtn.setAttribute("aria-checked", String(next === "dark"));
    });
  }

  var langSelect = document.getElementById("lang-select");
  var langTrigger = document.getElementById("lang-select-trigger");
  var langList = document.getElementById("lang-select-list");
  if (langSelect && langTrigger && langList) {
    var closeList = function () {
      langList.hidden = true;
      langTrigger.setAttribute("aria-expanded", "false");
    };
    var openList = function () {
      langList.hidden = false;
      langTrigger.setAttribute("aria-expanded", "true");
    };
    var selectLang = function (next) {
      document.documentElement.setAttribute("data-lang", next);
      document.documentElement.setAttribute("lang", next);
      try { localStorage.setItem("lang", next); } catch (e) {}
      var titleAttr = next === "en" ? "data-title-en" : "data-title-ko";
      var newTitle = document.documentElement.getAttribute(titleAttr);
      if (newTitle) document.title = newTitle;
      updatePlaceholders();
      closeList();
    };
    langTrigger.addEventListener("click", function (e) {
      e.stopPropagation();
      if (langList.hidden) openList(); else closeList();
    });
    Array.prototype.forEach.call(langList.querySelectorAll("li[data-lang-value]"), function (li) {
      li.addEventListener("click", function () {
        selectLang(li.getAttribute("data-lang-value"));
      });
    });
    document.addEventListener("click", function (e) {
      if (!langSelect.contains(e.target)) closeList();
    });
    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") closeList();
    });
  }

  var subscribeForm = document.getElementById("subscribe-form");
  var subscribeStatus = document.getElementById("subscribe-status");
  if (subscribeForm && subscribeStatus) {
    var messages = {
      sending: { ko: "전송 중...", en: "Sending..." },
      confirm: { ko: "확인 메일을 보냈어요. 받은편지함에서 링크를 눌러 구독을 완료해주세요.", en: "Check your inbox — click the confirmation link to finish subscribing." },
      error: { ko: "문제가 발생했어요. 잠시 후 다시 시도해주세요.", en: "Something went wrong. Please try again." },
      network: { ko: "네트워크 오류가 발생했어요. 다시 시도해주세요.", en: "Network error. Please try again." }
    };
    var currentLang = function () {
      return document.documentElement.getAttribute("data-lang") || "ko";
    };
    var setStatus = function (key) {
      subscribeStatus.textContent = messages[key][currentLang()];
    };
    subscribeForm.addEventListener("submit", function (e) {
      e.preventDefault();
      var input = subscribeForm.querySelector('input[name="email"]');
      var submitBtn = subscribeForm.querySelector(".subscribe-submit");
      var email = input.value.trim();
      submitBtn.disabled = true;
      setStatus("sending");
      fetch("/api/subscribe", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email: email })
      })
        .then(function (r) {
          return r.json().then(function (data) { return { ok: r.ok, data: data }; });
        })
        .then(function (result) {
          submitBtn.disabled = false;
          if (result.ok) {
            setStatus("confirm");
            subscribeForm.reset();
          } else {
            setStatus("error");
          }
        })
        .catch(function () {
          submitBtn.disabled = false;
          setStatus("network");
        });
    });
  }

  var shareBtn = document.getElementById("share-button");
  var shareTooltip = document.getElementById("share-tooltip");
  var shareTooltipTimer = null;
  if (shareBtn) {
    shareBtn.addEventListener("click", function () {
      if (!navigator.clipboard || !navigator.clipboard.writeText) return;
      navigator.clipboard.writeText(window.location.href).then(function () {
        if (!shareTooltip) return;
        shareTooltip.classList.add("visible");
        if (shareTooltipTimer) clearTimeout(shareTooltipTimer);
        shareTooltipTimer = setTimeout(function () {
          shareTooltip.classList.remove("visible");
        }, 1600);
      }).catch(function () {});
    });
  }

  var termPanel = document.getElementById("term-panel");
  var termBackdrop = document.getElementById("term-panel-backdrop");
  var termClose = document.getElementById("term-panel-close");
  var termTitle = document.getElementById("term-panel-title");
  var termBody = document.getElementById("term-panel-body");
  var glossaryDataEl = document.getElementById("glossary-data");
  var glossaryData = {};
  if (glossaryDataEl) {
    try { glossaryData = JSON.parse(glossaryDataEl.textContent || "{}"); } catch (e) {}
  }
  if (termPanel && termBackdrop && termTitle && termBody) {
    var openTermPanel = function (term, entry) {
      var lang = document.documentElement.getAttribute("data-lang") || "ko";
      termTitle.textContent = term;
      termBody.textContent = entry[lang] || entry.ko || entry.en || "";
      termPanel.classList.add("open");
      termPanel.setAttribute("aria-hidden", "false");
      termBackdrop.hidden = false;
    };
    var closeTermPanel = function () {
      termPanel.classList.remove("open");
      termPanel.setAttribute("aria-hidden", "true");
      termBackdrop.hidden = true;
    };
    document.addEventListener("click", function (e) {
      var btn = e.target.closest && e.target.closest(".term-link");
      if (btn) {
        var term = btn.getAttribute("data-term");
        var entry = glossaryData[term];
        if (entry) openTermPanel(term, entry);
        return;
      }
      if (e.target === termBackdrop) closeTermPanel();
    });
    if (termClose) termClose.addEventListener("click", closeTermPanel);
    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") closeTermPanel();
    });
  }

  var searchInput = document.getElementById("archive-search-input");
  var searchResults = document.getElementById("archive-search-results");
  if (searchInput && searchResults) {
    var searchIndexPromise = null;
    var loadSearchIndex = function () {
      if (!searchIndexPromise) {
        searchIndexPromise = fetch("{{ css_prefix }}search-index.json")
          .then(function (r) { return r.json(); })
          .catch(function () { return []; });
      }
      return searchIndexPromise;
    };
    var escapeHtml = function (s) {
      return String(s).replace(/[&<>"']/g, function (c) {
        return { "&": "&amp;", "<": "&lt;", ">": "&gt;", "\"": "&quot;", "'": "&#39;" }[c];
      });
    };
    searchInput.addEventListener("focus", loadSearchIndex);
    searchInput.addEventListener("input", function () {
      var q = searchInput.value.trim().toLowerCase();
      if (!q) {
        searchResults.hidden = true;
        searchResults.innerHTML = "";
        return;
      }
      loadSearchIndex().then(function (data) {
        var matches = data.filter(function (item) {
          var haystack = ((item.title || "") + " " + (item.summary_ko || "") + " " + (item.summary_en || "")).toLowerCase();
          return haystack.indexOf(q) !== -1;
        }).slice(0, 20);
        searchResults.innerHTML = matches.map(function (item) {
          var href = "{{ archive_link_prefix }}" + item.date + ".html";
          return "<li><a href=\"" + href + "\">" + escapeHtml(item.title) + "</a>" +
                 "<span class=\"archive-search-date\">" + escapeHtml(item.date) + " · " + escapeHtml(item.source) + "</span></li>";
        }).join("");
        searchResults.hidden = matches.length === 0;
      });
    });
    document.addEventListener("click", function (e) {
      if (e.target !== searchInput && !searchResults.contains(e.target)) {
        searchResults.hidden = true;
      }
    });
  }
})();
</script>
</body>
</html>
