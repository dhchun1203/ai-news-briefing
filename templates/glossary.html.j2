<!DOCTYPE html>
{% set title_ko = "AI 용어사전 · Daily AI Thread" %}
{% set title_en = "AI Glossary · Daily AI Thread" %}
<html lang="ko" data-lang="ko" data-title-ko="{{ title_ko }}" data-title-en="{{ title_en }}">
<head>
<meta charset="UTF-8">
<title>{{ title_ko }}</title>
<meta name="description" content="AI 뉴스 브리핑에 등장한 AI 용어를 쉬운 말로 설명하는 용어사전">
<meta property="og:type" content="website">
<meta property="og:title" content="{{ title_ko }}">
<meta property="og:description" content="AI 뉴스 브리핑에 등장한 AI 용어를 쉬운 말로 설명하는 용어사전">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ title_ko }}">
<meta name="twitter:description" content="AI 뉴스 브리핑에 등장한 AI 용어를 쉬운 말로 설명하는 용어사전">
<link rel="canonical" href="{{ canonical_url }}">
<meta name="robots" content="index, follow">
<meta property="og:url" content="{{ canonical_url }}">
<meta property="og:image" content="{{ og_image_url }}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content="AI 뉴스 브리핑 · Daily AI Thread">
<meta name="twitter:image" content="{{ og_image_url }}">
<link rel="icon" type="image/svg+xml" href="favicon.svg">
{% if google_site_verification %}<meta name="google-site-verification" content="{{ google_site_verification }}">{% endif %}
{% if naver_site_verification %}<meta name="naver-site-verification" content="{{ naver_site_verification }}">{% endif %}
<script type="application/ld+json">{{ jsonld|tojson }}</script>
<script>
(function () {
  function getCookie(name) {
    var match = document.cookie.match(new RegExp("(?:^|; )" + name + "=([^;]*)"));
    return match ? decodeURIComponent(match[1]) : null;
  }
  try {
    var t = getCookie("theme");
    if (t === "dark" || t === "light") document.documentElement.setAttribute("data-theme", t);
    var l = localStorage.getItem("lang");
    if (l === "ko" || l === "en") {
      document.documentElement.setAttribute("data-lang", l);
      document.documentElement.setAttribute("lang", l);
      var titleAttr = l === "en" ? "data-title-en" : "data-title-ko";
      var storedTitle = document.documentElement.getAttribute(titleAttr);
      if (storedTitle) document.title = storedTitle;
    }
  } catch (e) {}
})();
</script>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@400;600;700&display=swap">
<link rel="stylesheet" href="site-base.css">
<link rel="stylesheet" href="site-mobile.css" media="(max-width: 767px)">
<link rel="stylesheet" href="site-desktop.css" media="(min-width: 768px)">
<script defer src="/_vercel/insights/script.js"></script>
</head>
<body>
<a class="skip-link" href="#main-content">
  <span class="lang-ko">본문으로 건너뛰기</span>
  <span class="lang-en">Skip to content</span>
</a>
<header class="site-header">
  <div class="utility-bar">
    <a class="glossary-nav-link" href="glossary.html">
      <span class="lang-ko">용어사전</span>
      <span class="lang-en">Glossary</span>
    </a>
    <div class="share-wrap" id="share-wrap">
      <button id="share-button" class="share-button" type="button" aria-label="링크 복사 / Copy link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
      </button>
      <span class="share-tooltip" id="share-tooltip" role="status" aria-live="polite">
        <span class="lang-ko">복사되었습니다</span>
        <span class="lang-en">Copied!</span>
      </span>
    </div>
    <div class="lang-select" id="lang-select">
      <button type="button" class="lang-select-trigger" id="lang-select-trigger" aria-haspopup="listbox" aria-expanded="false">
        <span class="lang-select-current lang-ko">한국어</span>
        <span class="lang-select-current lang-en">English</span>
        <span class="lang-select-caret" aria-hidden="true">▾</span>
      </button>
      <ul class="lang-select-list" id="lang-select-list" role="listbox" hidden>
        <li role="option" tabindex="-1" data-lang-value="ko">한국어</li>
        <li role="option" tabindex="-1" data-lang-value="en">English</li>
      </ul>
    </div>
    <button id="theme-toggle" class="theme-toggle" type="button" role="switch" aria-checked="false" aria-label="다크모드 전환">
      <span class="theme-toggle-thumb">
        <span class="icon-moon" aria-hidden="true">&#9789;</span>
        <span class="icon-sun" aria-hidden="true">&#9728;</span>
      </span>
    </button>
  </div>
  <div class="header-inner">
    <h1>
      <a href="index.html">
        <span class="lang-ko">AI 뉴스 브리핑</span>
        <span class="lang-en">AI News Briefing</span>
      </a>
    </h1>
    <p class="tagline">
      <span class="lang-ko">AI 용어사전 · 지금까지 브리핑에 등장한 용어 {{ terms|length }}개</span>
      <span class="lang-en">AI Glossary · {{ terms|length }} terms explained so far</span>
    </p>
  </div>
</header>

<main class="content" id="main-content">
  <div class="date-bar">
    <button type="button" class="glossary-back" id="glossary-back">
      <span class="lang-ko">← 이전 화면으로</span>
      <span class="lang-en">← Back</span>
    </button>
  </div>

  <p class="glossary-intro">
    <span class="lang-ko">매일 브리핑에서 어려운 용어가 나올 때마다 쉬운 말로 설명을 덧붙여왔습니다. 그 설명들을 한곳에 모았습니다.</span>
    <span class="lang-en">Every jargon term explained in a daily briefing ends up here, in plain language.</span>
  </p>

  {% if terms|length >= 2 %}
  <div class="glossary-graph-wrap">
    <p class="glossary-graph-label">
      <span class="lang-ko">용어 지도 · 점을 눌러 설명 보기</span>
      <span class="lang-en">Concept map · tap a node to see its explanation</span>
    </p>
    <div class="glossary-graph" id="glossary-graph">
      <svg class="glossary-graph-edges" id="glossary-graph-edges"></svg>
    </div>
  </div>
  <script type="application/json" id="glossary-graph-data">{{ graph_data|tojson }}</script>
  {% endif %}
  <script type="application/json" id="glossary-lookup-data">{{ term_lookup|tojson }}</script>

  <div class="glossary-search">
    <input type="search" id="glossary-search-input" class="glossary-search-input"
           data-placeholder-ko="용어 검색..." data-placeholder-en="Search terms..."
           aria-label="용어 검색 / Search terms">
  </div>

  {% if not terms %}
  <p class="empty-state">
    <span class="lang-ko">아직 등록된 용어가 없습니다. 브리핑이 쌓이면 여기도 함께 채워집니다.</span>
    <span class="lang-en">No terms yet — this fills in as daily briefings accumulate.</span>
  </p>
  {% endif %}

  <dl class="glossary-list" id="glossary-list">
    {% for t in terms %}
    <div class="glossary-term" data-search="{{ (t.term_ko ~ ' ' ~ t.term_en)|lower }}">
      <dt class="glossary-term-name">
        <span class="lang-ko">{{ t.term_ko }}</span>
        <span class="lang-en">{{ t.term_en }}</span>
      </dt>
      <dd class="glossary-term-desc">
        <span class="lang-ko">{{ t.explanation_ko }}</span>
        <span class="lang-en">{{ t.explanation_en }}</span>
      </dd>
    </div>
    {% endfor %}
  </dl>
</main>

<footer class="site-footer">
  <p>
    <span class="lang-ko">매일 08:00 KST 자동 갱신 · 마지막 생성: {{ generated_at }}</span>
    <span class="lang-en">Auto-updated daily at 08:00 KST · Last updated: {{ generated_at }}</span>
  </p>
</footer>

<div class="term-panel-backdrop" id="term-panel-backdrop" hidden></div>
<aside class="term-panel" id="term-panel" aria-hidden="true">
  <button type="button" class="term-panel-close" id="term-panel-close" aria-label="닫기 / Close">&times;</button>
  <p class="term-panel-label">
    <span class="lang-ko">용어 설명</span>
    <span class="lang-en">Glossary</span>
  </p>
  <h3 class="term-panel-title" id="term-panel-title"></h3>
  <p class="term-panel-body" id="term-panel-body"></p>
</aside>

<script>
(function () {
  var updatePlaceholders = function () {
    var lang = document.documentElement.getAttribute("data-lang") || "ko";
    Array.prototype.forEach.call(document.querySelectorAll("[data-placeholder-ko]"), function (el) {
      var attr = lang === "en" ? "data-placeholder-en" : "data-placeholder-ko";
      el.setAttribute("placeholder", el.getAttribute(attr) || "");
    });
  };
  updatePlaceholders();

  var themeBtn = document.getElementById("theme-toggle");
  if (themeBtn) {
    var isDarkActive = function () {
      return document.documentElement.getAttribute("data-theme") === "dark";
    };
    var setThemeCookie = function (value) {
      var expires = new Date();
      expires.setTime(expires.getTime() + 365 * 24 * 60 * 60 * 1000);
      document.cookie = "theme=" + encodeURIComponent(value) + "; expires=" + expires.toUTCString() + "; path=/; SameSite=Lax";
    };
    themeBtn.setAttribute("aria-checked", String(isDarkActive()));
    themeBtn.addEventListener("click", function () {
      var next = isDarkActive() ? "light" : "dark";
      document.documentElement.setAttribute("data-theme", next);
      setThemeCookie(next);
      themeBtn.setAttribute("aria-checked", String(next === "dark"));
    });
  }

  // 뒤로가기로 bfcache에서 페이지가 복원되면(pageshow persisted===true) 이
  // 스크립트가 다시 실행되지 않아 테마/언어가 떠날 때 상태로 얼어붙는다 — 용어사전
  // 안에서 언어를 바꾼 뒤 뒤로가기 버튼으로 다시 여기 돌아왔을 때를 대비해 다시
  // 동기화한다(정작 문제가 보고된 건 여기서 다른 페이지로 나갈 때지만, 반대
  // 방향도 동일한 문제라 같이 고친다).
  window.addEventListener("pageshow", function (e) {
    if (!e.persisted) return;
    function getCookie(name) {
      var match = document.cookie.match(new RegExp("(?:^|; )" + name + "=([^;]*)"));
      return match ? decodeURIComponent(match[1]) : null;
    }
    var t = getCookie("theme");
    if (t === "dark" || t === "light") {
      document.documentElement.setAttribute("data-theme", t);
      if (themeBtn) themeBtn.setAttribute("aria-checked", String(t === "dark"));
    }
    var l = localStorage.getItem("lang");
    if (l === "ko" || l === "en") {
      document.documentElement.setAttribute("data-lang", l);
      document.documentElement.setAttribute("lang", l);
      var titleAttr = l === "en" ? "data-title-en" : "data-title-ko";
      var storedTitle = document.documentElement.getAttribute(titleAttr);
      if (storedTitle) document.title = storedTitle;
    }
    updatePlaceholders();
  });

  var langSelect = document.getElementById("lang-select");
  var langTrigger = document.getElementById("lang-select-trigger");
  var langList = document.getElementById("lang-select-list");
  if (langSelect && langTrigger && langList) {
    var langOptions = Array.prototype.slice.call(langList.querySelectorAll("li[data-lang-value]"));
    var closeList = function (returnFocus) {
      langList.hidden = true;
      langTrigger.setAttribute("aria-expanded", "false");
      if (returnFocus) langTrigger.focus();
    };
    var openList = function (focusIndex) {
      langList.hidden = false;
      langTrigger.setAttribute("aria-expanded", "true");
      if (typeof focusIndex === "number" && langOptions[focusIndex]) langOptions[focusIndex].focus();
    };
    var selectLang = function (next) {
      document.documentElement.setAttribute("data-lang", next);
      document.documentElement.setAttribute("lang", next);
      try { localStorage.setItem("lang", next); } catch (e) {}
      var titleAttr = next === "en" ? "data-title-en" : "data-title-ko";
      var newTitle = document.documentElement.getAttribute(titleAttr);
      if (newTitle) document.title = newTitle;
      updatePlaceholders();
      closeList(true);
    };
    langTrigger.addEventListener("click", function (e) {
      e.stopPropagation();
      if (langList.hidden) openList(); else closeList();
    });
    langTrigger.addEventListener("keydown", function (e) {
      if (e.key === "ArrowDown" || e.key === "ArrowUp") {
        e.preventDefault();
        openList(e.key === "ArrowDown" ? 0 : langOptions.length - 1);
      }
    });
    langOptions.forEach(function (li, i) {
      li.addEventListener("click", function () {
        selectLang(li.getAttribute("data-lang-value"));
      });
      li.addEventListener("keydown", function (e) {
        if (e.key === "ArrowDown") {
          e.preventDefault();
          langOptions[(i + 1) % langOptions.length].focus();
        } else if (e.key === "ArrowUp") {
          e.preventDefault();
          langOptions[(i - 1 + langOptions.length) % langOptions.length].focus();
        } else if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          selectLang(li.getAttribute("data-lang-value"));
        } else if (e.key === "Escape") {
          closeList(true);
        }
      });
    });
    document.addEventListener("click", function (e) {
      if (!langSelect.contains(e.target)) closeList();
    });
    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") closeList();
    });
  }

  var termPanel = document.getElementById("term-panel");
  var termBackdrop = document.getElementById("term-panel-backdrop");
  var termClose = document.getElementById("term-panel-close");
  var termTitle = document.getElementById("term-panel-title");
  var termBody = document.getElementById("term-panel-body");
  var termTrigger = null;
  var lookupDataEl = document.getElementById("glossary-lookup-data");
  var termLookup = {};
  if (lookupDataEl) {
    try { termLookup = JSON.parse(lookupDataEl.textContent || "{}"); } catch (e) {}
  }
  var openTermPanel = function () {};
  if (termPanel && termBackdrop && termTitle && termBody) {
    openTermPanel = function (term, entry, trigger) {
      var lang = document.documentElement.getAttribute("data-lang") || "ko";
      termTitle.textContent = term;
      termBody.textContent = entry[lang] || entry.ko || entry.en || "";
      termPanel.classList.add("open");
      termPanel.setAttribute("aria-hidden", "false");
      termBackdrop.hidden = false;
      termTrigger = trigger || null;
      if (termClose) termClose.focus();
    };
    var closeTermPanel = function () {
      termPanel.classList.remove("open");
      termPanel.setAttribute("aria-hidden", "true");
      termBackdrop.hidden = true;
      if (termTrigger) { termTrigger.focus(); termTrigger = null; }
    };
    termBackdrop.addEventListener("click", closeTermPanel);
    if (termClose) termClose.addEventListener("click", closeTermPanel);
    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") closeTermPanel();
      if (e.key === "Tab" && termPanel.classList.contains("open")) {
        e.preventDefault();
        if (termClose) termClose.focus();
      }
    });
  }

  // 용어 지도: 누적된 용어들을 서로 밀어내면서(반발력) 연관 있는 것끼리는 당기고
  // (스프링), 살짝 무작위로 흔들려 "둥둥 떠다니는" 느낌을 주는 아주 단순한
  // force-directed 레이아웃. 외부 라이브러리 없이 순수 JS로 매 프레임 위치만
  // 갱신하고, 실제 노드는 일반 <button>이라 클릭/포커스/스크린리더가 그대로
  // 동작한다 — 이 그래프는 아래 목록의 시각적 보조 수단일 뿐, 목록이 이미
  // 접근성 있는 전체 데이터를 제공한다.
  var graphWrap = document.getElementById("glossary-graph");
  var graphDataEl = document.getElementById("glossary-graph-data");
  if (graphWrap && graphDataEl) {
    var graphData = {};
    try { graphData = JSON.parse(graphDataEl.textContent || "{}"); } catch (e) {}
    var gNodes = graphData.nodes || [];
    var gEdges = graphData.edges || [];
    if (gNodes.length >= 2) {
      var svgNS = "http://www.w3.org/2000/svg";
      var edgesSvg = document.getElementById("glossary-graph-edges");
      var W = graphWrap.clientWidth || 600;
      var H = graphWrap.clientHeight || 320;
      edgesSvg.setAttribute("viewBox", "0 0 " + W + " " + H);

      var nodeState = gNodes.map(function (n, i) {
        var angle = (i / gNodes.length) * Math.PI * 2;
        var radius = Math.min(W, H) * 0.32;
        return {
          term: n.term,
          x: W / 2 + Math.cos(angle) * radius,
          y: H / 2 + Math.sin(angle) * radius,
          vx: 0,
          vy: 0
        };
      });
      var indexByTerm = {};
      nodeState.forEach(function (n, i) { indexByTerm[n.term] = i; });
      var edgePairs = gEdges
        .map(function (e) { return [indexByTerm[e[0]], indexByTerm[e[1]]]; })
        .filter(function (p) { return p[0] !== undefined && p[1] !== undefined; });

      var nodeEls = gNodes.map(function (n) {
        var btn = document.createElement("button");
        btn.type = "button";
        btn.className = "glossary-node";
        btn.setAttribute("data-term", n.term);
        var koSpan = document.createElement("span");
        koSpan.className = "lang-ko";
        koSpan.textContent = n.label_ko;
        var enSpan = document.createElement("span");
        enSpan.className = "lang-en";
        enSpan.textContent = n.label_en;
        btn.appendChild(koSpan);
        btn.appendChild(enSpan);
        btn.addEventListener("click", function () {
          var entry = termLookup[n.term];
          if (entry) openTermPanel(n.term, entry, btn);
        });
        graphWrap.appendChild(btn);
        return btn;
      });

      var lineEls = edgePairs.map(function () {
        var line = document.createElementNS(svgNS, "line");
        line.setAttribute("class", "glossary-graph-line");
        edgesSvg.appendChild(line);
        return line;
      });

      var reduceMotion = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      var tick = function () {
        for (var i = 0; i < nodeState.length; i++) {
          for (var j = i + 1; j < nodeState.length; j++) {
            var a = nodeState[i], b = nodeState[j];
            var dx = a.x - b.x, dy = a.y - b.y;
            var distSq = dx * dx + dy * dy || 0.01;
            var dist = Math.sqrt(distSq);
            var force = 1800 / distSq;
            var fx = (dx / dist) * force, fy = (dy / dist) * force;
            a.vx += fx; a.vy += fy;
            b.vx -= fx; b.vy -= fy;
          }
        }
        edgePairs.forEach(function (p) {
          var a = nodeState[p[0]], b = nodeState[p[1]];
          var dx = b.x - a.x, dy = b.y - a.y;
          var dist = Math.sqrt(dx * dx + dy * dy) || 0.01;
          var target = Math.min(W, H) * 0.34;
          var force = (dist - target) * 0.02;
          var fx = (dx / dist) * force, fy = (dy / dist) * force;
          a.vx += fx; a.vy += fy;
          b.vx -= fx; b.vy -= fy;
        });
        nodeState.forEach(function (n) {
          n.vx += (W / 2 - n.x) * 0.001;
          n.vy += (H / 2 - n.y) * 0.001;
          if (!reduceMotion) {
            n.vx += (Math.random() - 0.5) * 0.6;
            n.vy += (Math.random() - 0.5) * 0.6;
          }
          n.vx *= 0.85; n.vy *= 0.85;
          n.x += n.vx; n.y += n.vy;
          var margin = 44;
          n.x = Math.max(margin, Math.min(W - margin, n.x));
          n.y = Math.max(margin, Math.min(H - margin, n.y));
        });
        nodeEls.forEach(function (btn, i) {
          var n = nodeState[i];
          btn.style.setProperty("--x", n.x + "px");
          btn.style.setProperty("--y", n.y + "px");
        });
        lineEls.forEach(function (line, i) {
          var p = edgePairs[i];
          var a = nodeState[p[0]], b = nodeState[p[1]];
          line.setAttribute("x1", a.x); line.setAttribute("y1", a.y);
          line.setAttribute("x2", b.x); line.setAttribute("y2", b.y);
        });
      };

      if (reduceMotion) {
        for (var iter = 0; iter < 150; iter++) tick();
      } else {
        var rafId = null;
        var loop = function () { tick(); rafId = requestAnimationFrame(loop); };
        loop();
        document.addEventListener("visibilitychange", function () {
          if (document.hidden) { if (rafId) cancelAnimationFrame(rafId); }
          else { loop(); }
        });
      }
    }
  }

  var glossaryBack = document.getElementById("glossary-back");
  if (glossaryBack) {
    // 용어사전은 오늘자/지난 아카이브/영어권 페이지 등 어디서든 들어올 수 있어
    // 고정된 링크 하나로는 정확한 원래 위치를 알 수 없다 — 실제 방문 이력으로 되돌아간다.
    // 직접 주소로 들어와 이력이 없는 경우(history.length가 1)에는 홈으로 대체.
    glossaryBack.addEventListener("click", function () {
      if (window.history.length > 1) {
        window.history.back();
      } else {
        window.location.href = "index.html";
      }
    });
  }

  var shareBtn = document.getElementById("share-button");
  var shareTooltip = document.getElementById("share-tooltip");
  var shareTooltipTimer = null;
  if (shareBtn) {
    shareBtn.addEventListener("click", function () {
      if (!navigator.clipboard || !navigator.clipboard.writeText) return;
      navigator.clipboard.writeText(window.location.href).then(function () {
        if (!shareTooltip) return;
        shareTooltip.classList.add("visible");
        if (shareTooltipTimer) clearTimeout(shareTooltipTimer);
        shareTooltipTimer = setTimeout(function () {
          shareTooltip.classList.remove("visible");
        }, 1600);
      }).catch(function () {});
    });
  }

  // 용어사전은 이미 전체 목록이 서버에서 렌더링돼 있어서(fetch 불필요), 입력할 때마다
  // 각 항목의 data-search 속성과 단순 부분 문자열 비교만 하면 된다.
  var glossarySearch = document.getElementById("glossary-search-input");
  var glossaryList = document.getElementById("glossary-list");
  if (glossarySearch && glossaryList) {
    var terms = Array.prototype.slice.call(glossaryList.querySelectorAll(".glossary-term"));
    glossarySearch.addEventListener("input", function () {
      var q = glossarySearch.value.trim().toLowerCase();
      terms.forEach(function (el) {
        var haystack = el.getAttribute("data-search") || "";
        el.hidden = q.length > 0 && haystack.indexOf(q) === -1;
      });
    });
  }
})();
</script>
</body>
</html>
