# 이 파일을 복사해 .env로 저장하고 실제 값을 채우세요 (cp .env.example .env).
# .env는 .gitignore에 등록되어 있으므로 커밋되지 않습니다.
# 이 6개 변수는 로컬 테스트용 .env 뿐 아니라, Vercel 프로젝트 설정과 Claude Code Routine
# Environment 양쪽에도 동일하게 등록해야 합니다 (README.md "이메일 구독 설정" 참고).

# Supabase 프로젝트 설정 → API 에서 확인 (service_role 키, anon 키 아님)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# resend.com에서 발급. 발신 도메인 인증 후의 주소를 RESEND_SENDER_EMAIL에 사용
# (onboarding@resend.dev 샌드박스 주소로는 임의의 구독자에게 발송 불가)
RESEND_API_KEY=
RESEND_SENDER_EMAIL=

# 확인/구독취소 링크 서명용 임의 문자열 (python -c "import secrets; print(secrets.token_urlsafe(32))")
SUBSCRIBE_TOKEN_SECRET=

# 배포된 사이트 URL, 끝에 슬래시 없이 (예: https://ai-news-briefing-taupe.vercel.app)
SITE_URL=
